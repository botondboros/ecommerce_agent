# Grocery Agent — Credentials
# Copy this to .env and fill in your details
# Never commit .env to git

# Kifli.hu
KIFLI_EMAIL=your@email.com
KIFLI_PASSWORD=yourpassword

# Auchan Online
AUCHAN_EMAIL=your@email.com
AUCHAN_PASSWORD=yourpassword

# Tesco Online
TESCO_EMAIL=your@email.com
TESCO_PASSWORD=yourpassword

# Anthropic API (for AI brand recommendations and store scoring)
ANTHROPIC_API_KEY=sk-ant-...

# Bot settings
HEADLESS=false      # true = no browser window
SLOW_MO=400         # ms delay between actions
